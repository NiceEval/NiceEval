{
  "name": "codex-sdk-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "lsof -ti tcp:31001 | xargs kill -9 2>/dev/null; concurrently -k -n server,web -c blue,green \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:server": "node --env-file .env --import tsx/esm --watch src/backend/server.ts",
    "dev:web": "wait-on -t 30000 tcp:127.0.0.1:31001 && vite",
    "build": "vite build",
    "start": "node --env-file .env --import tsx/esm src/backend/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.24",
    "@openai/codex-sdk": "^0.142.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^7.0.0",
    "wait-on": "^9.0.0"
  }
}
