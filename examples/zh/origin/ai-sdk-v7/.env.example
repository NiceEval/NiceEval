# OpenAI 兼容 provider 的鉴权(src/backend/models.ts 里读)。
OPENAI_API_KEY=sk-replace-me
# 可选:OpenAI-compatible 网关
#OPENAI_BASE_URL=https://api.openai.com/v1

DEEPSEEK_API_KEY=sk-replace-me
#DEEPSEEK_BASE_URL=https://api.deepseek.com

# 可选:没传参数时用的默认模型。
#AGENT_MODEL=deepseek-v4-flash

# 可选:server.ts 监听端口,默认 34001。
#PORT=34001

# OTel tracing 默认开启(AI SDK 官方 @ai-sdk/otel 集成,见 src/backend/otel.ts),导出到 <endpoint>/v1/traces。
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
