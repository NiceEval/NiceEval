# query() 会把这些透传给 Claude Code CLI 子进程做鉴权 / 路由。
# 默认走官方 Anthropic API;如果要接 DeepSeek 等 Anthropic 兼容端点,改下面两个即可。
ANTHROPIC_API_KEY=sk-ant-replace-me
ANTHROPIC_BASE_URL=https://api.anthropic.com

# options.model 接受 'claude-sonnet-5' 这类别名,也接受模型服务商自己的 model id
# (比如接 DeepSeek 时用 deepseek-v4-flash)。
AGENT_MODEL=claude-sonnet-5

# 可选:src/backend/server.ts 监听端口,默认 32001。
#PORT=32001

# OTel 遥测默认开启(Claude Code CLI 原生机制,零代码,query() 子进程继承这些变量;导出的是 metrics + logs,不是 trace spans)。
CLAUDE_CODE_ENABLE_TELEMETRY=1
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_EXPORTER_OTLP_PROTOCOL=http/json
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
