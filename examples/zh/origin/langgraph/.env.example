# agent 怎么召模型:真的经 LangGraph StateGraph 的 agent 循环召一个 OpenAI 兼容模型。
# server.py 用 python-dotenv 在启动时加载这个文件。
OPENAI_API_KEY=sk-replace-me
# 可选:OpenAI 兼容网关
#OPENAI_BASE_URL=https://api.openai.com/v1
# 可选:用的模型,默认 gpt-4o-mini。
#AGENT_MODEL=gpt-4o-mini
# 可选:HTTP 服务器端口,默认 35000。
#PORT=35000

# LangSmith OTel-only 导出默认开启(Python 零代码,指向 docker-compose.yml 起的本地 Jaeger;改了要重启 server.py)。
LANGSMITH_TRACING=true
LANGSMITH_OTEL_ENABLED=true
LANGSMITH_OTEL_ONLY=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
