# DeepSeek 鉴权 —— @earendil-works/pi-ai 的 deepseekProvider() 自动读这个环境变量
# (envApiKeyAuth(["DEEPSEEK_API_KEY"])，不用在代码里手动传 apiKey)。deepseek-v4-flash /
# deepseek-v4-pro 都在它的模型目录里，baseUrl 固定是 https://api.deepseek.com。
DEEPSEEK_API_KEY=sk-replace-me

# 可选：deepseek-v4-flash(默认) / deepseek-v4-pro。
#AGENT_MODEL=deepseek-v4-flash

# 可选：src/backend/server.ts 监听端口，默认 33001。
#PORT=33001
