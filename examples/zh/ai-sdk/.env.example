# 默认是 mock 模式，不需要 API key，适合先验证 fasteval 接线。
# 要跑真实 AI SDK tool loop，设置:
#   AGENT_MODE=ai
#   OPENAI_API_KEY=...
AGENT_MODE=mock

OPENAI_API_KEY=
OPENAI_BASE_URL=
AGENT_MODEL=gpt-4o-mini

# 可选：端口，默认 5188
PORT=5188

# 可选：应用自己的 Langfuse 观测。先在 ./langfuse 里启动 docker compose，
# 再把该 compose 的 LANGFUSE_INIT_PROJECT_*_KEY 填到这里。
# 这些值不要提交到 git；这里只保留示例占位。
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-replace-me
LANGFUSE_SECRET_KEY=sk-lf-replace-me
