{
  "name": "niceeval",
  "version": "0.4.6",
  "description": "Agent-native eval tool — eval agents, services, functions, and coding-agent fixtures",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NiceEval/NiceEval.git"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "niceeval": "bin/niceeval.js"
  },
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./sandbox": {
      "types": "./src/sandbox/index.ts",
      "import": "./src/sandbox/index.ts"
    },
    "./sandbox/e2b-template": {
      "types": "./src/sandbox/e2b-agent-template.ts",
      "import": "./src/sandbox/e2b-agent-template.ts"
    },
    "./adapter": {
      "types": "./src/agents/index.ts",
      "import": "./src/agents/index.ts"
    },
    "./adapter/otel": {
      "types": "./src/agents/ai-sdk-otel.ts",
      "import": "./src/agents/ai-sdk-otel.ts"
    },
    "./expect": {
      "types": "./src/expect/index.ts",
      "import": "./src/expect/index.ts"
    },
    "./reporters": {
      "types": "./src/runner/reporters/index.ts",
      "import": "./src/runner/reporters/index.ts"
    },
    "./loaders": {
      "types": "./src/loaders/index.ts",
      "import": "./src/loaders/index.ts"
    },
    "./results": {
      "types": "./src/results/index.ts",
      "import": "./src/results/index.ts"
    },
    "./report": {
      "types": "./dist/report/index.d.ts",
      "import": "./dist/report/index.js"
    },
    "./report/react": {
      "types": "./dist/report/react/index.d.ts",
      "import": "./dist/report/react/index.js"
    },
    "./report/built-in": {
      "types": "./dist/report/built-in/index.d.ts",
      "import": "./dist/report/built-in/index.js"
    },
    "./report/react/styles.css": "./src/report/assets/styles.css",
    "./report/react/enhance.js": "./src/report/assets/enhance.js"
  },
  "files": [
    "INDEX.md",
    "src",
    "bin",
    "dist",
    "docs-site/zh",
    "docs-site/images"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "niceeval": "node bin/niceeval.js",
    "e2e": "tsx e2e/scripts/run.ts",
    "gen:diff-code": "tsx scripts/gen-diff-code.ts",
    "docs:reference": "tsx scripts/generate-reference.ts",
    "tiers:sync": "node scripts/sync-tiers.mjs sync",
    "tiers:check": "node scripts/sync-tiers.mjs check",
    "view:build": "vite build --config src/view/app/vite.config.ts",
    "build:report": "tsc -p tsconfig.report-build.json && node scripts/prune-report-dist.mjs",
    "build:index": "tsx scripts/generate-reference.ts --bundled-index",
    "prepare": "pnpm run view:build && pnpm run build:report && pnpm run build:index",
    "site:dev": "cd site && node scripts/dev.mjs",
    "site:build": "cd site && next build && cd .. && tsx scripts/submit-indexnow.ts",
    "docs:dev": "node scripts/docs-dev.mjs",
    "docs:validate": "cd docs-site && npx --yes mint@latest validate",
    "docs:links": "cd docs-site && npx --yes mint@latest broken-links --check-anchors --check-redirects"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "autoevals": "0.0.132",
    "effect": "^3.21.4",
    "mermaid": "^11.16.0",
    "tar-stream": "^3.1.7",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@ai-sdk/otel": "^1.0.9",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@radix-ui/react-collapsible": "^1.1.14",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-tabs": "^1.1.15",
    "@tailwindcss/vite": "^4.3.1",
    "@types/dockerode": "^3.3.31",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/tar-stream": "^3.1.3",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@vercel/sandbox": "^2.2.1",
    "@vitejs/plugin-react": "^6.0.3",
    "braintrust": "^3.20.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dockerode": "^4.0.2",
    "e2b": "^2.31.0",
    "lucide-react": "^1.21.0",
    "mixpanel-browser": "^2.80.0",
    "next": "16.2.10",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-grab": "^0.1.48",
    "shiki": "^4.3.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@ai-sdk/otel": ">=1.0.0",
    "@opentelemetry/exporter-trace-otlp-http": ">=0.200.0",
    "@opentelemetry/sdk-trace-node": ">=2.0.0",
    "@vercel/sandbox": ">=2.0.0",
    "ai": ">=5.0.0",
    "braintrust": ">=0.0.150",
    "dockerode": ">=4.0.0",
    "e2b": ">=2.0.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/otel": {
      "optional": true
    },
    "@vercel/sandbox": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "braintrust": {
      "optional": true
    },
    "@opentelemetry/exporter-trace-otlp-http": {
      "optional": true
    },
    "@opentelemetry/sdk-trace-node": {
      "optional": true
    },
    "dockerode": {
      "optional": true
    },
    "e2b": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
