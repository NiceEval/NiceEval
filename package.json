    "fastevals": "node bin/fastevals.mjs"
  },
  "dependencies": {
    "dockerode": "^4.0.2",
    "tar-stream": "^3.1.7",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.31",
    "@types/node": "^22.0.0",
    "@types/tar-stream": "^3.1.3",
    "typescript": "^5.6.0"
  }
}
