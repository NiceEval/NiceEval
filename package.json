{
  "name": "fastevals",
  "version": "0.0.1",
  "description": "写得快、跑得快、看得快的 TypeScript evals 库",
  "type": "module",
  "license": "MIT",
  "bin": {
    "fastevals": "bin/fastevals.mjs"
  },
  "exports": {
    ".": "./src/index.ts",
    "./expect": "./src/expect/index.ts",
    "./reporters": "./src/runner/reporters/index.ts",
    "./loaders": "./src/loaders/index.ts"
  },
  "files": [
    "src",
    "bin"
  ],
  "scripts": {
