# e2e 用的最小变量集(CI 由 workflow 从 secrets 写入同样内容)。
CODEX_API_KEY=sk-replace-me
CODEX_BASE_URL=https://your-proxy.example.com/v1

# judge(t.judge.autoevals.*)用独立凭证。这个网关只认 deepseek-v4-pro / deepseek-v4-flash
# 这两个模型名(niceeval.config.ts 的 judge.model 已按此设置)。
NICEEVAL_JUDGE_KEY=sk-replace-me
NICEEVAL_JUDGE_BASE=https://your-judge-endpoint.example.com/v1
