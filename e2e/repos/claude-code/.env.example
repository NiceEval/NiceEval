# e2e 用的最小变量集(CI 由 workflow 从 secrets 写入同样内容)。
# claude CLI(沙箱里跑)接 DeepSeek 的 Anthropic 兼容端点(带 /anthropic)。
ANTHROPIC_API_KEY=sk-replace-me
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# judge(t.judge.autoevals.*)用独立凭证,niceeval.config.ts 里 judge.model 是 gpt-5.4。
NICEEVAL_JUDGE_KEY=sk-replace-me
NICEEVAL_JUDGE_BASE=https://your-judge-endpoint.example.com/v1
