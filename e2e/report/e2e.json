{
  "id": "report",
  "group": "report",
  "command": [
    "pnpm",
    "e2e"
  ],
  "timeoutMinutes": 10,
  "secrets": [
    "OPENAI_API_KEY",
    "OPENAI_BASE_URL",
    "NICEEVAL_JUDGE_KEY",
    "NICEEVAL_JUDGE_BASE"
  ],
  "artifacts": [
    ".niceeval/**",
    "site-export/**",
    "main.xml",
    "fail.xml",
    "error.xml",
    "main.ndjson",
    "logs/**"
  ],
  "requires": {
    "runtimes": [
      "node>=22"
    ]
  }
}
